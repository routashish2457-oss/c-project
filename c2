#include<stdio.h>
#include<stdlib.h>
struct node{
int data;
struct node*link;
};
int main()
{
struct node *head,*current,*temp;
head=malloc(sizeof(struct node));
head->data=45;
head->link=NULL;
current=malloc(sizeof(struct node));
current->data=98;
current->link=NULL;
head->link=current;
temp=head;
while(temp!=NULL){
printf("%d->",temp->data);
temp=temp->link;
}
printf("NULL\n");
return 0;
}
