#include <stdio.h>

void insertionSort(int dataArray[], int n) {
    int i, j, key;

    // Loop starts from the second element (index 1)
    for (i = 1; i < n; i++) {
        key = dataArray[i]; // Store the current element
        j = i - 1;          // Start comparing with the element before

        /* Shift elements of dataArray[0..i-1] that are 
           greater than key to one position ahead of 
           their current position */
        while (j >= 0 && dataArray[j] > key) {
            dataArray[j + 1] = dataArray[j];
            j = j - 1;
        }
        dataArray[j + 1] = key; // Place the key in its correct position
    }
}
