#include<stdio.h>
int findelement(int arr[],int n,int key)
{
    int i;
    for(i=0;i<n;i++)
    if (arr[i]==key)
    return i;
}
int main()
{
    int arr[]={1,2,4,6,8};
    int n=sizeof(arr)/sizeof(arr[0]);
    int key=4;
    int position=findelement(arr,n,key);
    if(position==-1)
    printf("element not found");
    else
    printf("element found at position:%d",position+1);
    return 0;
}
