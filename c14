#include<stdio.h>
#include<stdlib.h>
int main()
{
    int *ptr;
    ptr=(int *)malloc(10*sizeof(int));
    if(ptr==NULL)
    {
        printf("sorry...no space.\n");
    }
else
{
printf("successful memory allocation.\n");
for(int i=0;i<=5;i++)
{
ptr[i]=i;
}
printf("the elements are:\n");
for(int i=1;i<=5;i++)
{
printf("%d\n",ptr[i]);
}
}
}
